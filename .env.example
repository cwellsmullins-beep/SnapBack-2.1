# Copy this file to .env.local and fill in your values

# Required: OpenAI API key for AI-generated summaries
OPENAI_API_KEY=sk-...

# Optional: Override the model used (default: gpt-4o-mini)
# gpt-4o-mini is fast and cheap for this use case
# gpt-4o is slower/more expensive but produces better summaries
OPENAI_MODEL=gpt-4o-mini
